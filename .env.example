# === Gemini (필수 — 현재 유일하게 사용 중인 AI) ===
GEMINI_API_KEY=             # Google AI Studio에서 발급
GEMINI_TEXT_MODEL=          # 기본값: gemini-2.5-flash (비워두면 기본값 사용)
GEMINI_IMAGE_MODEL=         # 기본값: gemini-2.5-flash-image

# === 아래는 아직 미구현 — 추후 연동 시 필요 ===
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# ANTHROPIC_API_KEY=          # Claude 연동 시
# OPENAI_API_KEY=             # GPT Image 연동 시
# REPLICATE_API_TOKEN=        # Stability AI 인페인팅 연동 시
# COUPANG_ACCESS_KEY=         # 쿠팡 파트너스 API
# COUPANG_SECRET_KEY=
