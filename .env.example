# === Supabase (필수) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === AI APIs (필수) ===
ANTHROPIC_API_KEY=          # Claude - 카피/태그 생성
OPENAI_API_KEY=             # GPT Image - 이미지 생성
REPLICATE_API_TOKEN=        # Stability AI - 인페인팅

# === Gemini (필수 - 텍스트/이미지 생성에 사용) ===
GEMINI_API_KEY=             # Google AI Studio에서 발급
GEMINI_TEXT_MODEL=          # 기본값: gemini-2.5-flash (비워두면 기본값 사용)
GEMINI_IMAGE_MODEL=         # 기본값: gemini-2.5-flash-preview-image-generation

# === 선택 ===
COUPANG_ACCESS_KEY=         # 쿠팡 파트너스 API
COUPANG_SECRET_KEY=         # 쿠팡 파트너스 API
