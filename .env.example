# ─────────────────────────────────────────────────────────────
# PageCraft 환경변수 — 이 파일을 .env.local 로 복사해서 채우세요
#   cp .env.example .env.local
# 자세한 설명: README.md 3번 / docs/api-keys.md
# ─────────────────────────────────────────────────────────────

# === 인증 시크릿 (필수) ===
# 로그인 세션·초대 토큰 JWT 서명용. 16자 이상 랜덤.
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# === Gemini (무료 체험 서버 키) ===
# 무료 체험 사용자는 이 키로 AI를 돌림 (운영자 비용). BYOK 사용자는 본인 키 사용.
# 발급: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=          # 기본값: gemini-2.5-flash
GEMINI_IMAGE_MODEL=         # 기본값: gemini-2.5-flash-image

# === 구글 OAuth (로그인 — 관리자 + 무료 체험 사용자 공용) ===
# https://console.cloud.google.com → 사용자 인증 정보 → OAuth 클라이언트
# 승인된 리디렉션 URI에 등록:
#   로컬:  http://localhost:3000/api/oauth/google/callback
#   배포:  https://<도메인>/api/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === 관리자 (필수) ===
# /admin 접근 가능한 구글 이메일. 쉼표 구분. AI 무제한.
ADMIN_EMAILS=

# === Redis (운영 필수 / 로컬 선택) ===
# 초대 링크·체험 크레딧 저장. 없으면 메모리 폴백(서버리스/재시작 시 데이터 소실).
# Upstash: https://upstash.com
KV_REDIS_URL=

# === 앱 공개 주소 (운영 권장) ===
# 초대 링크·OAuth 콜백 기준 주소. 커스텀 도메인이면 필수.
# 없으면 요청 origin 자동 추정 (로컬/단순 배포는 대개 OK).
NEXT_PUBLIC_APP_URL=

# === 에러 모니터링 Sentry (선택) ===
# NEXT_PUBLIC_SENTRY_DSN=    # 클라이언트 에러
# SENTRY_DSN=                # 서버 에러
